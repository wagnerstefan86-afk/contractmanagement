# ============================================================
# Contract Analysis Platform — Environment Configuration
# ============================================================
# Copy this file to .env and populate the values before starting.
# Variables left blank use their documented defaults.

# ── LLM Settings ────────────────────────────────────────────
# Master switch. Set to false to run fully deterministic (no LLM calls).
# Stages 4.5, 5, and 8 gracefully degrade to rule-based output when disabled.
LLM_ENABLED=true

# Provider: anthropic | openai   (default: anthropic)
LLM_PROVIDER=anthropic

# Model override. Leave blank to use the provider default:
#   anthropic → claude-opus-4-6
#   openai    → gpt-4o
LLM_MODEL=

# Unified API key — overrides provider-specific keys below.
# Prefer provider-specific keys (less ambiguity when switching providers).
LLM_API_KEY=

# Provider-specific keys (used when LLM_API_KEY is not set)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Per-request LLM call timeout in seconds (default: 60)
LLM_TIMEOUT_SECONDS=60

# ── Auth / JWT ───────────────────────────────────────────────
# IMPORTANT: Set a stable random secret in non-dev environments.
# If unset, a random secret is generated per process — tokens are invalidated
# on every restart.
JWT_SECRET=

# JWT token lifetime in hours (default: 8)
JWT_EXPIRY_HOURS=8

# ── Stage 5 Semantic Retrieval ───────────────────────────────
# TF-IDF retrieval is dependency-free and always available.
# Set to false to disable semantic candidate expansion (deterministic only).
STAGE5_SEMANTIC_RETRIEVAL_ENABLED=true

# Number of top semantic candidates returned per clause query (default: 5)
STAGE5_SEMANTIC_TOP_K=5

# Maximum merged shortlist size: deterministic + semantic candidates (default: 8)
STAGE5_MAX_CANDIDATES=8

# Minimum cosine similarity score for a semantic candidate to be included (default: 0.15)
STAGE5_MIN_SEMANTIC_SCORE=0.15

# ── Evaluation / Benchmark Mode ──────────────────────────────
# Set to true only when running benchmark evaluations offline.
# Writes benchmark_comparison_stage5.json and benchmark_metrics_stage5.json.
# Never enable in production.
CONTRACT_EVAL_MODE=false

# Path to benchmark golden set JSON (only used when CONTRACT_EVAL_MODE=true)
# STAGE5_BENCHMARK_PATH=tests/fixtures/eval_benchmark.json
