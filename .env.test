# ============================================================
# Contract Analysis Platform — Test-Instance Environment
# ============================================================
# NOT production hardened. Use for browser-based testing only.
#
# Usage:
#   cp .env.test .env
#   Edit .env: set NEXT_PUBLIC_API_URL to your server's IP/hostname
#   docker compose build && docker compose up -d
# ============================================================

# ── Frontend → Backend URL (CRITICAL — set before docker compose build) ───────
# The browser uses this URL to reach the backend API.
# Replace with your server IP or hostname.
# Example: http://192.168.1.50:8765   or   http://myserver.example.com:8765
NEXT_PUBLIC_API_URL=http://localhost:8765

# ── LLM Settings ─────────────────────────────────────────────────────────────
# Start with LLM disabled for a clean deterministic baseline.
# All pipeline stages run in rule-based fallback mode — no external calls.
LLM_ENABLED=false

# Uncomment to enable LLM mode after verifying the deterministic baseline:
# LLM_ENABLED=true
# LLM_PROVIDER=anthropic               # anthropic | openai
# LLM_MODEL=                           # leave blank for provider default
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# LLM_TIMEOUT_SECONDS=60

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# IMPORTANT: Set a fixed secret so tokens survive backend restarts.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
# Leave blank only if you are ok with all sessions being invalidated on restart.
JWT_SECRET=replace-with-a-random-hex-string-before-use
JWT_EXPIRY_HOURS=8

# ── Stage 5 Semantic Retrieval ────────────────────────────────────────────────
# TF-IDF retrieval is built-in — no external dependencies.
STAGE5_SEMANTIC_RETRIEVAL_ENABLED=true
STAGE5_SEMANTIC_TOP_K=5
STAGE5_MAX_CANDIDATES=8
STAGE5_MIN_SEMANTIC_SCORE=0.15

# ── Benchmark Mode ────────────────────────────────────────────────────────────
# Never enable in a running test instance.
CONTRACT_EVAL_MODE=false
